  <property name="styleSheet">
   <string notr="true">/* Основное окно */
QMainWindow {
    background-color: #000000;
}

/* Все текстовые метки и поля ввода */
QLineEdit, QSpinBox, QTableWidget, QComboBox {
    color: #00FF00; /* Ярко-зеленый &quot;терминальный&quot; цвет */
    background-color: #000000;
    border: 1px solid #00FF00;
    font-family: &quot;Courier New&quot;, monospace; /* Или специальный пиксельный шрифт */
}

/* Кнопки Load Data и Calculate Metrics */
QPushButton {
    background-color: #000000;
    color: #00FF00;
    border: 2px solid #00FF00;
    padding: 5px;
    text-transform: uppercase;
    font-weight: bold;
}

QPushButton:hover {
    background-color: #00FF00;
    color: #000000;
}

QPushButton:pressed {
    background-color: #008800;
}

/* Настройка таблицы */
QTableWidget {
    gridline-color: #00FF00;
    selection-background-color: #004400;
    selection-color: #00FF00;
}

QHeaderView::section {
    background-color: #000000;
    color: #00FF00;
    border: 1px solid #00FF00;
    padding: 4px;
}

#outputErrorLabel, #regionErrorLabel {
    color: #FF0000; 
    border: none;
    font-family: &quot;Courier New&quot;, monospace;
}
QTableWidget QTableCornerButton::section {
    background-color: #000000;
    border: 1px solid #00FF00;
}</string>
